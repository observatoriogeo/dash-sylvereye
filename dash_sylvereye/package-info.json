{
  "name": "dash_sylvereye",
  "version": "0.3.0",
  "description": "Dash Sylvereye is a Plotly Dash component library for producing interactive web-based visualizations of large primal road networks in Python.",

  "main": "build/index.js",
  "scripts": {
    "start": "webpack serve --config ./webpack.serve.config.js --open",
    "validate-init": "python _validate_init.py",
    "prepublishOnly": "npm run validate-init",
    "build:js": "webpack --mode production",
    "build:backends": "dash-generate-components ./src/lib/components dash_sylvereye -p package-info.json --r-prefix '' --jl-prefix '' --ignore \\.test\\.",
    "build:backends-activated": "(. venv/bin/activate || venv\\scripts\\activate && npm run build:py_and_r)",
    "build": "npm run build:js && npm run build:backends",
    "build:activated": "npm run build:js && npm run build:backends-activated"
  },
  "author": "Alberto Garcia-Robledo <alberto.garob@gmail.com>",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.22.1",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.22.2",
    "@babel/preset-react": "^7.22.3",
    "@eslint/js": "^9.39.4",
    "@plotly/dash-component-plugins": "^1.2.3",
    "@plotly/webpack-dash-dynamic-import": "^1.2.0",
    "babel-loader": "^9.1.2",
    "copyfiles": "^2.1.1",
    "css-loader": "^6.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-docgen": "^5.4.3",
    "react-dom": "^18.3.1",
    "style-loader": "^3.3.3",
    "webpack": "^5.107.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4",

    "leaflet": "^1.9.4",
    "pixi.js": "^7.4.3",
    "rbush": "^3.0.1",
    "react-leaflet": "^4.2.1",
    "chroma-js": "^2.1.0",
    "leaflet-pixi-overlay": "^1.9.5",
    "jsts": "^2.5.1"
  },
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=10.0.0"
  }
}
